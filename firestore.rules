rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'malerovi2014@gmail.com';
    }

    function isSelf(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function pendingCreateKeys() {
      return request.resource.data.keys().hasOnly(['email', 'name', 'phone', 'status', 'createdAt', 'vehicleMake', 'vehicleModel'])
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email.lower()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.phone is string
        && request.resource.data.phone.matches('[0-9]{8,20}')
        && request.resource.data.vehicleMake is string
        && request.resource.data.vehicleMake.size() > 0
        && request.resource.data.vehicleMake.size() <= 80
        && request.resource.data.vehicleModel is string
        && request.resource.data.vehicleModel.size() > 0
        && request.resource.data.vehicleModel.size() <= 80
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp;
    }

    function onlyClearingReveal() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinRevealOnce'])
        && !('pinRevealOnce' in request.resource.data);
    }

    match /driverAccounts/{uid} {
      allow get: if isAdmin() || isSelf(uid);
      allow list: if isAdmin();
      allow create: if isSelf(uid) && pendingCreateKeys();
      allow update: if isAdmin()
        || (isSelf(uid) && onlyClearingReveal());
      allow delete: if isAdmin();
    }

    match /drivers/{pin} {
      allow get: if isAdmin()
        || (request.auth != null
          && resource.data.uid is string
          && resource.data.uid == request.auth.uid);
      allow list: if false;
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasAll(['name', 'phone', 'active', 'uid'])
        && request.resource.data.name is string
        && request.resource.data.phone is string
        && request.resource.data.active is bool
        && request.resource.data.uid is string;
      allow delete: if isAdmin();
    }

    match /config/{docId} {
      allow get: if isAdmin();
      allow list: if false;
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasAll(['adminPinHash', 'driverPins']);
      allow delete: if false;
    }

    match /accessLogs/{logId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['pinHint', 'name', 'phone', 'at', 'ua', 'uid'])
        && request.resource.data.pinHint is string
        && request.resource.data.pinHint.size() <= 2
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 80
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 20
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.at is timestamp
        && request.resource.data.ua is string
        && request.resource.data.ua.size() <= 160;
      allow read, list: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
