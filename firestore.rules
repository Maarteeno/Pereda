rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function hasWriteToken() {
      return request.resource != null
        && request.resource.data.writeToken == 'APT_WRITE_2026';
    }

    function deleteHasWriteToken() {
      return resource != null && resource.data.writeToken == 'APT_WRITE_2026';
    }

    match /drivers/{pin} {
      allow get: if true;
      allow list: if false;
      allow create, update: if hasWriteToken()
        && request.resource.data.keys().hasAll(['name', 'phone', 'active', 'writeToken']);
      allow delete: if deleteHasWriteToken();
    }

    match /config/{docId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if hasWriteToken()
        && request.resource.data.keys().hasAll(['adminPinHash', 'driverPins', 'writeToken']);
      allow delete: if false;
    }
  }
}
